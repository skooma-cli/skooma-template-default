package main

import (
	"log"
	"os"

	"github.com/gin-gonic/gin"
	"github.com/joho/godotenv"
)

func main() {
	// Load environment variables
	if err := godotenv.Load(); err != nil {
		log.Println("No .env file found")
	}

	// Create Gin router
	r := gin.Default()

	// Health check endpoint
	r.GET("/healthh", func(c *gin.Context) {
		c.JSON(200, gin.H{
			"status": "ok",
			"service": "{{.Name}}-backend",
		})
	})

	// Get port from environment or default to 8080
	port := os.Getenv("PORT")
	if port == "" {
		port = "8080"
	}

	log.Printf("Starting {{.Name}} backend server on port %s", port)
	r.Run(":" + port)
}